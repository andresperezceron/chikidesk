<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Título principal -->
        <TextView
            android:id="@+id/txvTituloConfig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mostrando_configuracion_para"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginBottom="16dp"/>

        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="16dp"/>

        <!-- Máquina seleccionada -->
        <TextView
            android:text="@string/maquina"
            style="@style/SmallTitleTextViewStyle"/>

        <TextView
            android:id="@+id/txvNombreMaquina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Molde seleccionado -->
        <TextView
            android:text="@string/molde"
            style="@style/SmallTitleTextViewStyle"/>

        <TextView
            android:id="@+id/txvNombreMolde"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Temperaturas -->
        <TextView
            android:text="@string/temperaturas_c"
            style="@style/BigTitleTextViewStyle"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="4"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/txvTemp1"
                style="@style/RoundedTextViewStyle"/>

            <TextView
                android:id="@+id/txvTemp2"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvTemp3"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvTemp4"
                style="@style/RoundedTextViewStyle"/>
        </LinearLayout>

        <!-- Inyección -->
        <TextView
            android:text="@string/inyecci_n_mm_s_y_bar"
            style="@style/BigTitleTextViewStyle"/>

        <!-- Título Velocidades -->
        <TextView
            android:text="@string/velocidades_mm_s"
            style="@style/SmallTitleTextViewStyle" />

        <!-- Fila de velocidades -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="5"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/txvInyVel1"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyVel2"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyVel3"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyVel4"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyVel5"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

        <TextView
            android:text="@string/presiones_bar"
            style="@style/SmallTitleTextViewStyle" />

    <!-- Fila de presiones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="5"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/txvInyPre1"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyPre2"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyPre3"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyPre4"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvInyPre5"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

        <TextView
            android:text="@string/retenpresi_n_vel_pres_tiempo"
            style="@style/BigTitleTextViewStyle"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/txvRetenVelocidad"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvRetenPresion"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvRetenTiempo"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

        <TextView
            android:text="@string/plastificacion"
            style="@style/BigTitleTextViewStyle"/>

        <TextView
            android:id="@+id/txvPlastificacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <TextView
            android:text="@string/expulsor_vel_pres_posicion"
            style="@style/BigTitleTextViewStyle"/>

        <TextView
            android:text="@string/velocidades_mm_s"
            style="@style/SmallTitleTextViewStyle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/txvExpulsorVel1"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvExpulsorVel2"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

        <TextView
            android:text="@string/presiones_bar"
            style="@style/SmallTitleTextViewStyle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/txvExpulsorPre1"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvExpulsorPre2"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

        <TextView
            android:text="@string/posiciones_mm"
            style="@style/SmallTitleTextViewStyle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/txvExpulsorPos1"
                style="@style/RoundedTextViewStyle" />

            <TextView
                android:id="@+id/txvExpulsorPos2"
                style="@style/RoundedTextViewStyle" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>