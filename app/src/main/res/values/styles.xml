<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RoundedTextViewStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:background">@drawable/textview_rounded</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="onConfigDetalleTituloPequeno">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:textColor">@android:color/darker_gray</item>
    </style>

    <style name="onConfigDetalleTituloPequenoIzquierda">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">46dp</item>
        <item name="android:paddingEnd">1dp</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:textColor">@android:color/darker_gray</item>
    </style>

    <style name="onConfigDetalleTituloPequenoDerecha">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">54dp</item>
        <item name="android:paddingEnd">1dp</item>
        <item name="android:layout_marginBottom">2dp</item>
        <item name="android:textColor">@android:color/darker_gray</item>
    </style>

    <style name="onConfigDetalleTituloGrande">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@android:color/holo_blue_dark</item>
    </style>

    <style name="onConfigDetalleNombreMoldeMaquina">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">20sp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="onConfigDetalleLinLayMarginBotton20dp">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <style name="onConfigDetalleLinLayMarginBotton6dp">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="onConfigDetalleLinLayTitulosPequenos">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center</item>
        <item name="android:weightSum">2</item>
    </style>

    <style name="onConfigDetalleValoresSinBorde">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <style name="onConfigDetalleTxvObservaciones">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:background">@drawable/textview_rounded</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:layout_marginBottom">20dp</item>
    </style>

    <style name="onConfigShowBigTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textColor">@color/gris1</item>
    </style>

    <!-- onAllApp !-->
    <style name="onAllAppHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="onAllAppSpacer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">26dp</item>
    </style>

    <!-- On Star App !-->
    <style name="onStarAppHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:text">@string/chikidesk</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_marginBottom">48dp</item>
    </style>


    <style name="onStarAppLinearLayoutMain">
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:padding">28dp</item>
        <item name="android:background">@drawable/bg_main</item>
    </style>

    <style name="onStartAppButtons">
        <item name="android:layout_width">240dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gris1</item>
    </style>

    <style name="onStarAppSpace">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">16dp</item>
    </style>

    <!-- onMoldeForm !-->
    <style name="onMoldeFormDivisorLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/gris1</item>
    </style>

    <style name="onMoldeFormEditTexts">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:inputType">text</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>